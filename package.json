{
  "name": "echolog",
  "version": "0.1.0",
  "description": "Local-first developer activity recorder and review engine",
  "type": "module",
  "bin": {
    "el": "./dist/cli/index.js"
  },
  "scripts": {
    "dev": "tsx src/server/app.ts",
    "build": "tsup && pnpm --filter web build",
    "build:server": "tsup",
    "cli": "tsx src/cli/index.ts",
    "mcp": "tsx src/mcp/server.ts",
    "migrate": "tsx src/migrate.ts",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/static": "^8.1.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "commander": "^13.1.0",
    "drizzle-orm": "^0.44.0",
    "ejs": "^3.1.10",
    "fastify": "^5.3.0",
    "nanoid": "^5.1.5",
    "node-notifier": "^10.0.1",
    "postgres": "^3.4.7",
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/node": "^22.15.0",
    "@types/node-notifier": "^8.0.5",
    "drizzle-kit": "^0.31.0",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
