server:
  port: 19827
  host: "0.0.0.0"
  # 非本机请求访问 /api/* 需携带此 key（X-API-Key 头或 ?apiKey= 参数）；本机请求豁免。
  # 留空或删除此行则完全关闭鉴权。生成方式：openssl rand -hex 24
  apiKey: "change-me"
  # serveWeb: false 表示此进程只提供 /api 纯 JSON 接口，不托管静态 Web UI。
  # serveWeb: false
  # corsOrigins 是允许跨源浏览器访问的 origin 白名单数组；默认不允许跨源。
  # 同源请求和非浏览器客户端不受影响。
  # 浏览器访问本 server 托管的 Web UI 属同源，仅需 apiKey。
  # 仅当前端与 API 不同源时（例如独立开发服务器提供前端）才需要配置 corsOrigins。
  # corsOrigins:
  #   - "http://localhost:5173"
  #   - "http://192.168.1.10:5173"

database:
  host: "localhost"
  port: 5436
  name: "echolog"
  user: "echolog"
  password: "echolog"

sync:
  target: "/path/to/your/notes/echolog"
  auto: false

# 屏幕前台应用采样（仅 macOS；被动记录哪个应用用了多久）
# idle_seconds：无键鼠输入超过此秒数视为离开；前台应用在播放视频/通话时不受此限
tracker:
  enabled: true
  sample_seconds: 5
  idle_seconds: 180

notifications:
  enabled: true
  mac: true
  ntfy:
    enabled: false
    server: "https://ntfy.sh"
    topic: "echolog-change-me"
  rules:
    task_overtime_minutes: 120
    idle_reminder_enabled: true
    idle_check_start: "09:00"
    idle_check_end: "18:00"
    daily_report_time: "21:00"
    end_of_day_time: "23:00"
